# ---------------------------------------------------------------------------
# Filters -- declarative safety nets. Ordered specific-first for the
# longest-prefix-wins registry; per-service caps stay tight because
# rewrites already projected most calls to short tab-separated rows.
# ---------------------------------------------------------------------------

# High-volume specific commands.

!filter az-monitor-activity-log
!match az monitor activity-log
!drop "^$"
!max-line-len 240
!max-lines 60
!overflow "+{n} more events"

!filter az-storage-blob
!match az storage blob
!drop "^$"
!max-line-len 240
!max-lines 100
!overflow "+{n} more blobs"

!filter az-acr-repository
!match az acr repository
!drop "^$"
!max-line-len 240
!max-lines 80
!overflow "+{n} more"

# Per-service catch-all filters (longest-prefix wins vs the generic aws
# filter and vs each other).

!filter az-group
!match az group
!drop "^$"
!max-line-len 200
