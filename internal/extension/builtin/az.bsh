!extension az v:1.0

# Azure CLI compaction. Same two-line defense as the AWS pack:
#
#   1. Rewrites project verbose JSON responses to a compact tab-separated
#      form using the tool's own JMESPath dialect (--query) plus --output
#      tsv. Every rewrite guards on --output / --query / -o so a caller
#      who asked for a specific shape (json, table, yaml, tsv, jsonc) is
#      never overridden.
#
#   2. Per-service filters cap line length and total lines as a safety
#      net. They fire after the rewrite (or in place of it, when the
#      guard tripped), so an --output json response the caller demanded
#      stays bounded.
#
# az supports the same JMESPath dialect as AWS via --query, and its
# --output tsv mode drops JSON braces + field names, so the compression
# ratio is comparable: a plain `az vm list` on 20 VMs drops from a
# multi-KB JSON blob to a few short rows.

# ---------------------------------------------------------------------------
# Verbs -- short aliases for the highest-frequency listing commands.
# ---------------------------------------------------------------------------

!verb azgroups
!expand exec az group list
!help "List Azure resource groups"

!verb azvms
!expand exec az vm list
!help "List VMs across the current subscription"

!verb azaks
!expand exec az aks list
!help "List AKS clusters"

!verb azkv
!expand exec az keyvault list
!help "List Key Vaults"

!verb azstorage
!expand exec az storage account list
!help "List storage accounts"

!verb azwebapps
!expand exec az webapp list
!help "List App Service web apps"

!verb azfuncs
!expand exec az functionapp list
!help "List Function Apps"

!verb azsql
!expand exec az sql server list
!help "List SQL servers"

!verb azcosmos
!expand exec az cosmosdb list
!help "List Cosmos DB accounts"

!verb azacr
!expand exec az acr list
!help "List Container Registries"

!verb azroles
!expand exec az role assignment list
!help "List role assignments in the current scope"

!verb azsub
!expand exec az account show
!help "Show the currently selected subscription"

# ---------------------------------------------------------------------------
# Rewrites -- reshape verbose JSON to compact tab-separated text via the
# az CLI's --query (JMESPath) and --output tsv. Guarded on --output /
# --query / -o so explicit intent (json, table, yaml, jsonc) always wins.
# ---------------------------------------------------------------------------

# Resource management

!rewrite az-group-list
!match az group list
!unless --output --query -o
!to "az group list --query '[].[name,location]' --output tsv"
!announce true

!rewrite az-resource-list
!match az resource list
!unless --output --query -o
!to "az resource list --query '[].[name,type,location,resourceGroup]' --output tsv"
!announce true

!rewrite az-deployment-group-list
!match az deployment group list
!unless --output --query -o
!to "az deployment group list --query '[].[name,properties.provisioningState,properties.timestamp]' --output tsv"
!announce true

!rewrite az-deployment-sub-list
!match az deployment sub list
!unless --output --query -o
!to "az deployment sub list --query '[].[name,properties.provisioningState,properties.timestamp]' --output tsv"
!announce true

