!extension gcloud v:1.0

# Google Cloud CLI compaction. Same two-line defense as the AWS / Azure
# packs, adapted to gcloud's own projection language:
#
#   1. Rewrites project verbose default output (a padded table with
#      headers and column dividers) to a bare tab-separated form using
#      gcloud's own --format="value(field1,field2,...)". Every rewrite
#      guards on --format so a caller who asked for a specific shape
#      (json, yaml, csv, a bespoke table) is never overridden.
#
#   2. Per-service filters cap line length and total lines as a safety
#      net. They fire after the rewrite (or in place of it, when the
#      guard tripped), so an --format=json response the caller demanded
#      stays bounded.
#
# gcloud's value() projection is the sharpest compaction knob available:
# no header row, no padding, one record per line, tab-separated fields.
# The .basename() transform trims resource URIs down to their last path
# segment (`.../machineTypes/n1-standard-1` → `n1-standard-1`), which is
# the single biggest per-cell win for Compute output.

# ---------------------------------------------------------------------------
# Verbs -- short aliases for the highest-frequency listing commands.
# ---------------------------------------------------------------------------

!verb gcpprojects
!expand exec gcloud projects list
!help "List GCP projects the caller can access"

!verb gcpvms
!expand exec gcloud compute instances list
!help "List Compute Engine VM instances"

!verb gcpdisks
!expand exec gcloud compute disks list
!help "List Compute Engine disks"

!verb gcpnetworks
!expand exec gcloud compute networks list
!help "List VPC networks"

!verb gcpfw
!expand exec gcloud compute firewall-rules list
!help "List VPC firewall rules"

!verb gcpgke
!expand exec gcloud container clusters list
!help "List GKE clusters"

!verb gcprun
!expand exec gcloud run services list
!help "List Cloud Run services"

!verb gcpfns
!expand exec gcloud functions list
!help "List Cloud Functions"

!verb gcpsql
!expand exec gcloud sql instances list
!help "List Cloud SQL instances"

!verb gcpbuckets
!expand exec gcloud storage buckets list
!help "List Cloud Storage buckets"

!verb gcpsecrets
!expand exec gcloud secrets list
!help "List Secret Manager secrets"

!verb gcpsa
!expand exec gcloud iam service-accounts list
!help "List IAM service accounts"

# ---------------------------------------------------------------------------
# Rewrites -- reshape verbose default table output to tab-separated form
# via gcloud's own --format="value(...)". Guarded on --format so explicit
# intent (json, yaml, csv, custom table) always wins.
# ---------------------------------------------------------------------------

# Projects / auth / config / services

!rewrite gcloud-projects-list
!match gcloud projects list
!unless --format
!to "gcloud projects list --format='value(projectId,name,projectNumber,lifecycleState)'"
!announce true

!rewrite gcloud-organizations-list
!match gcloud organizations list
!unless --format
!to "gcloud organizations list --format='value(name,displayName,creationTime,lifecycleState)'"
!announce true

!rewrite gcloud-resource-manager-folders-list
!match gcloud resource-manager folders list
!unless --format
!to "gcloud resource-manager folders list --format='value(name,displayName,lifecycleState)'"
!announce true

!rewrite gcloud-auth-list
!match gcloud auth list
!unless --format
!to "gcloud auth list --format='value(account,status)'"
!announce true

!rewrite gcloud-config-list
!match gcloud config list
!unless --format
!to "gcloud config list --format='value(core.project,core.account,compute.zone,compute.region)'"
!announce true

!rewrite gcloud-config-configurations-list
!match gcloud config configurations list
!unless --format
!to "gcloud config configurations list --format='value(name,is_active,account,project)'"
!announce true

!rewrite gcloud-services-list
!match gcloud services list
!unless --format
!to "gcloud services list --format='value(config.name,config.title)'"
!announce true

