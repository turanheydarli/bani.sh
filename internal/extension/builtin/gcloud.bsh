# ---------------------------------------------------------------------------
# Filters -- declarative safety nets. Ordered specific-first for the
# longest-prefix-wins registry; per-service caps stay tight because
# rewrites already projected most calls to short tab-separated rows.
# ---------------------------------------------------------------------------

!filter gcloud-logging-read
!match gcloud logging read
!drop "^$"
!max-line-len 240
!max-lines 100
!overflow "+{n} more entries"

# Per-service catch-all filters. `!match` is longest-prefix-wins.

!filter gcloud-projects
!match gcloud projects
!drop "^$"
!max-line-len 200
!max-lines 60
!overflow "+{n} more"

!filter gcloud-organizations
!match gcloud organizations
!drop "^$"
!max-line-len 200
!max-lines 60
!overflow "+{n} more"

!filter gcloud-resource-manager
!match gcloud resource-manager
!drop "^$"
!max-line-len 240
!max-lines 60
!overflow "+{n} more"

!filter gcloud-auth
!match gcloud auth
!drop "^$"
!max-line-len 200
!max-lines 30
!overflow "+{n} more"

!filter gcloud-config
!match gcloud config
!drop "^$"
!max-line-len 240
!max-lines 60
!overflow "+{n} more"

!filter gcloud-services
!match gcloud services
!drop "^$"
!max-line-len 240
!max-lines 100
!overflow "+{n} more"

!filter gcloud-compute
!match gcloud compute
!drop "^$"
!max-line-len 240
!max-lines 80
!overflow "+{n} more"

!filter gcloud-container
!match gcloud container
!drop "^$"
!max-line-len 240
!max-lines 60
!overflow "+{n} more"

!filter gcloud-storage
!match gcloud storage
!drop "^$"
!max-line-len 240
!max-lines 100
!overflow "+{n} more"

!filter gcloud-run
!match gcloud run
!drop "^$"
!max-line-len 240
!max-lines 60
!overflow "+{n} more"

!filter gcloud-functions
!match gcloud functions
!drop "^$"
!max-line-len 240
!max-lines 60
!overflow "+{n} more"

!filter gcloud-app
!match gcloud app
!drop "^$"
!max-line-len 240
!max-lines 60
!overflow "+{n} more"

!filter gcloud-sql
!match gcloud sql
!drop "^$"
!max-line-len 240
!max-lines 60
!overflow "+{n} more"

!filter gcloud-firestore
!match gcloud firestore
!drop "^$"
