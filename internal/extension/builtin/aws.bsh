!extension aws v:1.0

# AWS CLI compaction. Two lines of defense against multi-KB describe-* / list-*
# JSON payloads:
#
#   1. Rewrites project verbose JSON responses to a compact tab-separated
#      text form using the tool's own JMESPath dialect (--query) and
#      --output text. This is the biggest win by far: a single describe-
#      instances call routinely drops from 40k+ chars to a few hundred.
#      Every rewrite guards on --output / --query / -o so a caller who
#      asked for a specific shape (JSON, table, JMESPath projection) is
#      never overridden.
#
#   2. Filters cap line length and total lines as a safety net. They fire
#      after the rewrite (or in place of it, when the guard tripped), so
#      even a raw JSON response the caller demanded stays bounded.
#
# Verbs are short aliases; they lean on the rewrites, so `ec2ls` and
# `aws ec2 describe-instances` produce the same compact table.

# ---------------------------------------------------------------------------
# Verbs -- short aliases for the highest-frequency listing commands.
# ---------------------------------------------------------------------------

!verb s3ls
!args path
!expand exec aws s3 ls {path}
!help "List S3 buckets or objects at path"

!verb ec2ls
!expand exec aws ec2 describe-instances
!help "List EC2 instances (compact table)"

!verb lambdals
!expand exec aws lambda list-functions
!help "List Lambda functions"

!verb iamusers
!expand exec aws iam list-users
!help "List IAM users"

!verb iamroles
!expand exec aws iam list-roles
!help "List IAM roles"

!verb cfstacks
!expand exec aws cloudformation list-stacks
!help "List CloudFormation stacks"

!verb cfevents
!args stack
!expand exec aws cloudformation describe-stack-events --stack-name {stack}
!help "Recent stack events for a CloudFormation stack"

!verb loggroups
!expand exec aws logs describe-log-groups
!help "List CloudWatch log groups"

!verb rdslist
!expand exec aws rds describe-db-instances
!help "List RDS database instances"

!verb ddbtables
!expand exec aws dynamodb list-tables
!help "List DynamoDB tables"

!verb ecslist
!expand exec aws ecs list-clusters
!help "List ECS clusters"

!verb whoami
!expand exec aws sts get-caller-identity
!help "Show the current AWS caller identity"

# ---------------------------------------------------------------------------
# Rewrites -- reshape verbose JSON to compact text via the AWS CLI's own
# projection language. Each rewrite guards on the family of flags a caller
# would use to demand a specific format, so explicit intent always wins.
#
# The guard set (--output, --query, -o) also matches the "=" form
# (--output=json) via prefix match, so both spellings are honored.
# ---------------------------------------------------------------------------

# EC2

!rewrite aws-ec2-describe-instances
!match aws ec2 describe-instances
!unless --output --query -o
!to "aws ec2 describe-instances --query 'Reservations[].Instances[].[InstanceId,State.Name,InstanceType,PrivateIpAddress,PublicIpAddress]' --output text --no-cli-pager"
!announce true

!rewrite aws-ec2-describe-security-groups
!match aws ec2 describe-security-groups
!unless --output --query -o
!to "aws ec2 describe-security-groups --query 'SecurityGroups[].[GroupId,GroupName,VpcId,Description]' --output text --no-cli-pager"
!announce true

!rewrite aws-ec2-describe-volumes
!match aws ec2 describe-volumes
!unless --output --query -o
!to "aws ec2 describe-volumes --query 'Volumes[].[VolumeId,State,Size,VolumeType,AvailabilityZone]' --output text --no-cli-pager"
!announce true

!rewrite aws-ec2-describe-vpcs
!match aws ec2 describe-vpcs
!unless --output --query -o
!to "aws ec2 describe-vpcs --query 'Vpcs[].[VpcId,State,CidrBlock,IsDefault]' --output text --no-cli-pager"
!announce true

!rewrite aws-ec2-describe-subnets
!match aws ec2 describe-subnets
!unless --output --query -o
!to "aws ec2 describe-subnets --query 'Subnets[].[SubnetId,VpcId,CidrBlock,AvailabilityZone,State]' --output text --no-cli-pager"
!announce true

!rewrite aws-ec2-describe-images
!match aws ec2 describe-images
!unless --output --query -o
!to "aws ec2 describe-images --query 'Images[].[ImageId,Name,CreationDate,State]' --output text --no-cli-pager"
!announce true

