!to "aws bedrock list-custom-models --query 'modelSummaries[].[modelArn,modelName,baseModelName,creationTime]' --output text --no-cli-pager"
!announce true

!rewrite aws-xray-get-trace-summaries
!match aws xray get-trace-summaries
!unless --output --query -o
!to "aws xray get-trace-summaries --query 'TraceSummaries[].[Id,Duration,ResponseTime,HasError]' --output text --no-cli-pager"
!announce true

!rewrite aws-ce-list-cost-category-definitions
!match aws ce list-cost-category-definitions
!unless --output --query -o
!to "aws ce list-cost-category-definitions --query 'CostCategoryReferences[].[Name,CostCategoryArn,EffectiveStart]' --output text --no-cli-pager"
!announce true

!rewrite aws-budgets-describe-budgets
!match aws budgets describe-budgets
!unless --output --query -o
!to "aws budgets describe-budgets --query 'Budgets[].[BudgetName,BudgetType,TimeUnit]' --output text --no-cli-pager"
!announce true

!rewrite aws-mediaconvert-list-jobs
!match aws mediaconvert list-jobs
!unless --output --query -o
!to "aws mediaconvert list-jobs --query 'Jobs[].[Id,Status,CreatedAt,Queue]' --output text --no-cli-pager"
!announce true

!rewrite aws-medialive-list-channels
!match aws medialive list-channels
!unless --output --query -o
!to "aws medialive list-channels --query 'Channels[].[Id,Name,State,ChannelClass]' --output text --no-cli-pager"
!announce true

!rewrite aws-medialive-list-inputs
!match aws medialive list-inputs
!unless --output --query -o
!to "aws medialive list-inputs --query 'Inputs[].[Id,Name,Type,State]' --output text --no-cli-pager"
!announce true

!rewrite aws-mediapackage-list-channels
!match aws mediapackage list-channels
!unless --output --query -o
!to "aws mediapackage list-channels --query 'Channels[].[Id,Arn,Description]' --output text --no-cli-pager"
!announce true

# ---------------------------------------------------------------------------
# Filters -- declarative safety nets. Ordered specific-first for the longest-
# prefix-wins registry; per-service caps stay tight because rewrites already
# projected most calls to short tab-separated rows.
# ---------------------------------------------------------------------------

# Highest-volume specific commands first.

!filter aws-cloudformation-describe-stack-events
!match aws cloudformation describe-stack-events
!drop "^$"
!max-line-len 200
!max-lines 40
!overflow "+{n} more events"

!filter aws-logs-filter-log-events
!match aws logs filter-log-events
!drop "^$"
!max-line-len 240
!max-lines 100
!overflow "+{n} more events"

!filter aws-logs-tail
!match aws logs tail
!drop "^$"
!max-line-len 240
!max-lines 200
!overflow "+{n} more lines"

# Per-service catch-all filters. `!match` is longest-prefix-wins, so a more
# specific filter above still beats these.

!filter aws-ec2
!match aws ec2
!drop "^$"
!max-line-len 200
!max-lines 60
!overflow "+{n} more"

!filter aws-lambda
!match aws lambda
!drop "^$"
!max-line-len 200
!max-lines 60
!overflow "+{n} more"

